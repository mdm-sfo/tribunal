# =============================================================================
# The Tribunal — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your API keys.
# On EC2/remote servers, add these as exports in ~/.bashrc instead.
#
# See README.md "Feature Tiers" for what each key unlocks.
# =============================================================================

# ---------------------------------------------------------------------------
# CORE TIER (required — full deliberation engine with open-weight models)
# ---------------------------------------------------------------------------
TOGETHER_API_KEY=your_together_api_key_here

# ---------------------------------------------------------------------------
# ENHANCED TIER (optional — adds frontier model advocates)
# Add any combination. Each key adds one frontier advocate to the panel.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here      # Claude Sonnet
OPENAI_API_KEY=your_openai_api_key_here            # GPT-5
GOOGLE_API_KEY=your_google_api_key_here            # Gemini 2.5 Pro
FIREWORKS_API_KEY=your_fireworks_api_key_here      # Backup model routing

# ---------------------------------------------------------------------------
# AUDIO TIER (optional — dramatized podcast-style MP3 of the deliberation)
# Also requires ffmpeg installed: see README for instructions.
# ---------------------------------------------------------------------------
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ---------------------------------------------------------------------------
# OUTPUT & RUNTIME
# ---------------------------------------------------------------------------

# Where session files are saved. Defaults to ./conclave-sessions if unset.
TRIBUNAL_OUTPUT_DIR=/path/to/your/session/output

# Default deliberation depth: QUICK | BALANCED | THOROUGH | RIGOROUS | EXHAUSTIVE | NUCLEAR
CONCLAVE_DEFAULT_DEPTH=THOROUGH

# Maximum cost per session in USD (safety limit). Default: 5.00
CONCLAVE_MAX_COST=5.00

# ---------------------------------------------------------------------------
# NLI VALIDATION TIER (optional — GPU-accelerated claim verification)
# Requires a host with an NVIDIA GPU running nli_server.py.
# Without this, uses rule-based validation (still functional, less precise).
# ---------------------------------------------------------------------------
TRIBUNAL_NLI_URL=http://your-gpu-host:8787

# If using setup_nli_server.sh to deploy remotely, set these:
# NLI_GPU_HOST=your-gpu-hostname
# NLI_GPU_USER=your-ssh-username
